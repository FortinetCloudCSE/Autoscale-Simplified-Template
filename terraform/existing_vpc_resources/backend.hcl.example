# S3 backend configuration for existing_vpc_resources
#
# Copy this file to backend.hcl and fill in your values:
#   cp backend.hcl.example backend.hcl
#
# Then initialize Terraform with the backend config:
#   terraform init -backend-config=backend.hcl
#
# Using an S3 backend ensures tfstate survives if the machine running Terraform
# is replaced (e.g., after destroying and recreating the CloudFormation Linux instance).
# Without this, a fresh instance has no tfstate and will create duplicate resources.
#
# The S3 bucket must already exist. Create it with:
#   aws s3 mb s3://<your-bucket-name> --region <your-region>
#   aws s3api put-bucket-versioning --bucket <your-bucket-name> \
#     --versioning-configuration Status=Enabled
#
# Use different key paths for each deployment (cp/env) to avoid state collisions.

bucket = "your-terraform-state-bucket"
key    = "existing_vpc_resources/terraform.tfstate"
region = "us-west-2"

# Optional but recommended:
# encrypt        = true
# dynamodb_table = "terraform-state-lock"
