# =============================================================================
# Green Inspection Stack — terraform.tfvars
#
# Generated by discover.py from Blue autoscale_template.tfstate.
# Review all values before applying. Only fortios_version requires manual input.
#
# Deploy:
#   cd terraform/green_inspection_stack
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit: set fortios_version, fortigate_asg_password, keypair
#   terraform init
#   terraform apply
# =============================================================================

# ── Region and Availability Zones ─────────────────────────────────────────────
# Must match Blue deployment exactly.

aws_region          = "us-west-2"
availability_zone_1 = "a"
availability_zone_2 = "c"

# ── Resource Naming ────────────────────────────────────────────────────────────
# cp and env must match Blue so the management VPC is discovered correctly.
# asg_module_prefix MUST differ from Blue to avoid ASG resource name collisions.
#
# stack_label controls the infix in all VPC Name/Fortinet-Role tags:
#   "green" (default) → {cp}-{env}-green-inspection-* (no collision with Blue)
#   ""                → {cp}-{env}-inspection-*        (matches autoscale_template
#                                                        data sources for next cycle)
# After Phase 6 (Blue destroyed), set stack_label = "" and run terraform apply to
# rename tags in-place — no resources are recreated, only tags are updated.

cp                = "acme"
env               = "test"
asg_module_prefix = "green"   # REQUIRED: different from Blue (default "")
stack_label       = "green"   # Set to "" after Blue is destroyed (Phase 6)

# ── FortiGate Instance ─────────────────────────────────────────────────────────
# fgt_instance_type and firewall_policy_mode must match Blue.
# fortios_version is the only value not discovered from Blue state — set the
# target version here.

fgt_instance_type      = "c6i.xlarge"
fortios_version        = ""        # REQUIRED: set target FortiOS version (e.g. "7.6.2")
fortigate_asg_password = ""        # REQUIRED
keypair                = "my-keypair"
firewall_policy_mode   = "2-arm"   # Must match Blue: "1-arm" or "2-arm"
base_config_file       = "fgt-conf.cfg"

# ── Network ────────────────────────────────────────────────────────────────────
# vpc_cidr_inspection MUST be identical to Blue — required for config restore.
# subnet_bits MUST match Blue — determines identical subnet CIDR layout.

vpc_cidr_inspection = "10.0.0.0/16"   # Must match Blue exactly
vpc_cidr_management = "10.3.0.0/16"
vpc_cidr_spoke      = "192.168.0.0/16"
subnet_bits         = 8               # Must match Blue exactly

# ── Internet Egress ────────────────────────────────────────────────────────────
# Must match Blue deployment.
# nat_gw: Green NAT GWs start with temp EIPs; Blue EIPs migrated at cutover.
# eip: No NAT GWs created; each FortiGate gets its own EIP.

access_internet_mode = "nat_gw"   # Must match Blue: "nat_gw" or "eip"

# ── Management ─────────────────────────────────────────────────────────────────
# Must match Blue deployment.

enable_dedicated_management_vpc = false
enable_dedicated_management_eni = true

# ── Transit Gateway ────────────────────────────────────────────────────────────
# Green attaches to the same TGW as Blue.
# TGW route tables are NOT modified — that is the operator's responsibility.
# After apply, use output green_tgw_attachment_id to update spoke routes.

enable_tgw_attachment = true
attach_to_tgw_name    = "acme-test-tgw"

# ── GWLB Endpoint Names ────────────────────────────────────────────────────────
# These are the Name tags of the GWLB endpoints created by the module.
# The module names them using asg_module_prefix. Typical pattern:
#   "<asg_module_prefix>-<region><az>-endpoint"
# Run 'terraform apply' once then check the AWS console if unsure.

endpoint_name_az1 = "green-gwlbe_az1"
endpoint_name_az2 = "green-gwlbe_az2"

# ── Autoscale Group Capacity ───────────────────────────────────────────────────
# Match Blue desired/min/max so Green starts at the same capacity.

asg_byol_asg_min_size     = 1
asg_byol_asg_max_size     = 4
asg_byol_asg_desired_size = 2

asg_ondemand_asg_min_size     = 0
asg_ondemand_asg_max_size     = 4
asg_ondemand_asg_desired_size = 0

# ── GWLB Health Check ──────────────────────────────────────────────────────────
# Match Blue deployment.

gwlb_health_check_port     = 8008
gwlb_health_check_interval = 60
gwlb_healthy_threshold     = 5
asg_health_check_grace_period = 700

allow_cross_zone_load_balancing = true

# ── Licensing ──────────────────────────────────────────────────────────────────
# Match Blue licensing mode.
# BYOL: set asg_license_directory to S3 path containing license files.
# FortiFlex: set fortiflex_username, fortiflex_password, fortiflex_sn_list,
#            fortiflex_configid_list.
# PAYG: leave all licensing variables empty.
#
# NOTE: Both Blue and Green ASGs run simultaneously during the monitoring window.
# Ensure enough licenses are available for 2x capacity before applying.

asg_license_directory   = "asg_license"   # Must point to a directory (can be empty for FortiFlex/PAYG)
fortiflex_username      = ""
fortiflex_password      = ""
fortiflex_sn_list       = [""]
fortiflex_configid_list = [""]

# ── FortiManager Integration ───────────────────────────────────────────────────
# If enabled, Green FortiGates will connect to FortiManager with NEW serial numbers.
# FortiManager must re-authorize Green serials before cutover is valid.
# FortiManager 7.6.3+ requires: config system global / set fgfm-allow-vm enable

enable_fortimanager_integration = false
fortimanager_ip                 = ""
fortimanager_sn                 = ""
fortimanager_vrf_select         = 0

# ── Security Group ─────────────────────────────────────────────────────────────
# CIDRs allowed for FortiGate management access.

vpc_cidr_sg = ["0.0.0.0/0"]
